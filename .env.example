# Copy this file to .env.local and edit values.

# Core OCI
REGION=us-ashburn-1
COMPARTMENT_OCID=ocid1.compartment.oc1..replace
PROJECT_PREFIX=oci-splunk

# Optional OCI profile autodetection for deploy_oci_splunk.sh
# If ~/.oci/config exists, script can auto-read REGION and tenancy as fallback.
OCI_CONFIG_FILE=$HOME/.oci/config
OCI_PROFILE=DEFAULT

# Deployment mode: kafka | functions | both
MODE=kafka

# Create Splunk VM and network
CREATE_SPLUNK_INSTANCE=true
SPLUNK_SSH_PUBLIC_KEY_PATH=$HOME/.ssh/id_ed25519.pub
SPLUNK_ADMIN_PASSWORD=ChangeMe123!
ALLOW_INGRESS_CIDR=203.0.113.10/32
USE_EXISTING_SPLUNK=false
EXISTING_SPLUNK_WEB_URL=

# Optional if you want to pin image instead of auto-discovery
# SPLUNK_IMAGE_OCID=ocid1.image.oc1..<id>

# Stream/log resources
CREATE_STREAMING=true
CREATE_CONNECTOR_LOGS_TO_STREAM=true
LOG_GROUP_OCID=ocid1.loggroup.oc1..replace
LOG_OCID=ocid1.log.oc1..replace

# Kafka Connect generation and authentication
CREATE_KAFKA_CONNECT_FILES=true
CREATE_AUTH_TOKEN=false
TENANCY_NAME=replace_tenancy_name
STREAMING_USER_NAME=replace_user_name
STREAMING_USER_OCID=ocid1.user.oc1..replace
STREAMING_AUTH_TOKEN=replace_existing_auth_token_or_enable_create_auth_token
# Optional override. Default is: cell-1.streaming.${REGION}.oci.oraclecloud.com:9092
# KAFKA_BOOTSTRAP_SERVERS=

# Splunk HEC target (managed or existing Splunk)
SPLUNK_HEC_URL=https://splunk.example.com:8088/services/collector/event
SPLUNK_HEC_TOKEN=replace_with_hec_token
SPLUNK_HEC_INDEX=main

# Functions mode (optional)
CREATE_FN_APP=true
DEPLOY_FUNCTION_CODE=false
CREATE_CONNECTOR_LOGS_TO_FUNCTIONS=false
FN_APP_NAME=oci-splunk-fn-app
FN_NAME=splunk-hec-forwarder
# If empty, script reuses created subnet
FN_SUBNET_OCID=
# Required only if DEPLOY_FUNCTION_CODE=true
FN_IMAGE=
# Required if creating Logs->Functions connector without deploying function in this run
FUNCTION_OCID=
