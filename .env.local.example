# OCI CLI profile auto-discovery
OCI_CONFIG_FILE="$HOME/.oci/config"
OCI_PROFILE="DEFAULT"

# Core deployment
REGION="eu-frankfurt-1"
COMPARTMENT_OCID="ocid1.compartment.oc1..replace"
PROJECT_PREFIX="oci-splunk"

# Splunk VM
SPLUNK_INSTANCE_NAME="oci-splunk-splunk"
SPLUNK_SHAPE="VM.Standard.E5.Flex"
SPLUNK_OCPUS="2"
SPLUNK_MEMORY_GBS="16"
SPLUNK_BOOT_VOLUME_GBS="100"
# SSH key selection:
# - "generate" (default): generate new key pair automatically
# - "use": use SPLUNK_SSH_PUBLIC_KEY_PATH
SSH_KEY_SELECTION="generate"
SPLUNK_SSH_PUBLIC_KEY_PATH="$HOME/.ssh/id_ed25519.pub"
SPLUNK_ADMIN_PASSWORD="ChangeMe123!"
ALLOW_INGRESS_CIDR="203.0.113.10/32"

# OCI Logging source
LOG_GROUP_OCID="ocid1.loggroup.oc1..replace"
LOG_OCID="ocid1.log.oc1..replace"

# Streaming (reuse existing is recommended)
REUSE_EXISTING_STREAMING="true"
CREATE_STREAMING="true"
STREAM_POOL_NAME="oci-splunk-pool"
STREAM_NAME="Logs2Splunk"
STREAM_PARTITIONS="1"
STREAM_RETENTION_HOURS="24"

# Kafka auth for OCI Streaming Kafka compatibility
TENANCY_NAME="yourtenancy"
STREAMING_USER_NAME="oracleidentitycloudservice/user@company.com"
STREAMING_AUTH_TOKEN="replace-with-auth-token"
KAFKA_BOOTSTRAP_SERVERS="cell-1.streaming.eu-frankfurt-1.oci.oraclecloud.com:9092"

# Splunk HEC sink config
SPLUNK_HEC_URL="http://127.0.0.1:8088/services/collector/event"
# Leave placeholder to auto-generate token after provisioning on managed Splunk.
SPLUNK_HEC_TOKEN="TEMP_HEC_TOKEN_TO_REPLACE"
SPLUNK_HEC_INDEX="main"

# Existing Splunk mode (skip managed Splunk VM creation)
USE_EXISTING_SPLUNK="false"
EXISTING_SPLUNK_WEB_URL="https://your-splunk.example.com:8000"

# Optional mode
MODE="kafka"
